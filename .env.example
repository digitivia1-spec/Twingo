# ─── Build & runtime ────────────────────────────────────────────────────
NODE_ENV=development

# ─── Locale ─────────────────────────────────────────────────────────────
# Arabic is the default. The middleware honours this.
NEXT_PUBLIC_DEFAULT_LOCALE=ar

# ─── Data source (Phase 1 = mock, Phase 3 = supabase) ───────────────────
NEXT_PUBLIC_DATA_SOURCE=mock

# ─── Feedback system ────────────────────────────────────────────────────
# Enable the Sentry feedback widget + <FeedbackPin /> overlays.
# ONLY set on staging/preview, never on a true customer-facing deployment.
NEXT_PUBLIC_ENABLE_FEEDBACK=true

# Sentry DSN — client-side widget. Get this from your Sentry project.
NEXT_PUBLIC_SENTRY_DSN=

# Sentry organization + project (server-side, used at build time for source
# map uploads). Leave empty during local dev to skip the Sentry build wrapper.
SENTRY_ORG=digitivia-pt
SENTRY_PROJECT=twingo-demo
SENTRY_AUTH_TOKEN=

# ─── Optional: Resend (only if using /api/feedback email relay) ─────────
# Leave empty to use Sentry's native email alerts only (recommended week 1).
RESEND_API_KEY=
FEEDBACK_EMAIL_TO=a.nagui@digitivia.com
# Sender. Must be on a domain verified in Resend (add SPF/DKIM at OVH).
# Until you verify digitivia.com in Resend, Resend will reject the send.
# Shortcut for first test: use "Twinjo Demo <onboarding@resend.dev>".
FEEDBACK_EMAIL_FROM=Twinjo Demo <noreply@digitivia.com>

# ─── Incoming webhook secret ────────────────────────────────────────────
# Used by /api/feedback to verify Sentry webhook signatures.
SENTRY_WEBHOOK_SECRET=

# ─── Future: Supabase (Phase 3 — leave empty in Phase 1) ────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
